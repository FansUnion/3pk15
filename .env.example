# Fangrush / 三狼连猎 — local / deploy env template

# --- Site（本地固定端口 5000）---
NEXT_PUBLIC_SITE_URL=http://localhost:5000

# Shell: standalone | portal
NEXT_PUBLIC_APP_SHELL=standalone

# Ads: mock | adsense | portal_sdk
NEXT_PUBLIC_ADS_PROVIDER=mock

# Admin (standalone only). false → /admin 404
# Required for local admin: set true in .env.local
ADMIN_ENABLED=true
# Optional gate; leave empty for local-only trust
ADMIN_ACCESS_KEY=

# Telemetry: 0 = off (legacy; GA4 ID is hardcoded in apps/web/src/components/Ga4.tsx)
NEXT_PUBLIC_TELEMETRY=0

# Dev: force ad failures
# NEXT_PUBLIC_FAIL_ADS=1
