{
  "name": "@wolf-sheep/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @wolf-sheep/web-shared build",
    "dev": "next dev --turbopack -p 5000",
    "build": "next build",
    "build:portal": "node ./scripts/build-portal.mjs",
    "build:standalone": "node ./scripts/build-portal.mjs standalone",
    "build:poki": "node ./scripts/build-portal.mjs poki",
    "build:crazygames": "node ./scripts/build-portal.mjs crazygames",
    "start": "next start -p 5000",
    "lint": "next lint",
    "test": "vitest run",
    "check:assets": "node ./scripts/check-public-assets.mjs"
  },
  "dependencies": {
    "@wolf-sheep/game-core": "workspace:*",
    "@wolf-sheep/web-shared": "workspace:*",
    "next": "15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
