# Fangrush — Next 从本目录读 env（与仓库根 .env.example 保持一致）

# --- Site（本地固定端口 5000）---
NEXT_PUBLIC_SITE_URL=http://localhost:5000

# Shell: standalone | portal
NEXT_PUBLIC_APP_SHELL=standalone

# Ads: none | mock | adsense | portal_sdk. Use none for the standalone production site.
NEXT_PUBLIC_ADS_PROVIDER=none
NEXT_PUBLIC_PLATFORM=standalone
NEXT_PUBLIC_MOCK_AD_OUTCOME=success

ADMIN_ENABLED=true
ADMIN_ACCESS_KEY=

NEXT_PUBLIC_TELEMETRY=0

# NEXT_PUBLIC_FAIL_ADS=1
