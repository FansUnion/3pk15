{
  "name": "wolf-sheep",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @wolf-sheep/web dev",
    "build": "pnpm -r build",
    "build:portal": "pnpm --filter @wolf-sheep/web build:portal",
    "build:poki": "pnpm --filter @wolf-sheep/web build:poki",
    "build:crazygames": "pnpm --filter @wolf-sheep/web build:crazygames",
    "test": "pnpm --filter @wolf-sheep/game-core test",
    "test:web": "pnpm --filter @wolf-sheep/web test",
    "lint": "pnpm -r lint",
    "check:skins": "pnpm --filter @wolf-sheep/game-core check:skins",
    "check:assets": "pnpm --filter @wolf-sheep/web check:assets",
    "check:platform-boundaries": "node ./scripts/check-platform-boundaries.mjs",
    "audit:web-artifact": "node ./scripts/audit-web-artifact.mjs",
    "audit:portal-artifact": "node ./scripts/audit-web-artifact.mjs --strict",
    "release:check": "node ./scripts/release-check.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
