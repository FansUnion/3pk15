{
  "name": "wolf-sheep",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @wolf-sheep/player-web dev",
    "dev:player": "pnpm --filter @wolf-sheep/player-web dev",
    "dev:admin": "pnpm --filter @wolf-sheep/admin dev",
    "build:player": "pnpm --filter @wolf-sheep/player-web build",
    "build:admin": "pnpm --filter @wolf-sheep/admin build",
    "build:player:standalone": "pnpm --filter @wolf-sheep/player-web build:standalone",
    "build:player:poki": "pnpm --filter @wolf-sheep/player-web build:poki",
    "build:player:crazygames": "pnpm --filter @wolf-sheep/player-web build:crazygames",
    "build": "pnpm -r build",
    "build:standalone": "pnpm --filter @wolf-sheep/player-web build:standalone",
    "build:poki": "pnpm --filter @wolf-sheep/player-web build:poki",
    "build:crazygames": "pnpm --filter @wolf-sheep/player-web build:crazygames",
    "test": "pnpm --filter @wolf-sheep/game-core test",
    "test:web": "pnpm --filter @wolf-sheep/player-web test && pnpm --filter @wolf-sheep/admin test",
    "lint": "pnpm -r lint",
    "check:skins": "pnpm --filter @wolf-sheep/game-core check:skins",
    "check:assets": "pnpm --filter @wolf-sheep/web-assets check",
    "check:platform-boundaries": "node ./scripts/check-platform-boundaries.mjs",
    "audit:web-artifact": "node ./scripts/audit-web-artifact.mjs",
    "audit:portal-artifact": "node ./scripts/audit-web-artifact.mjs --strict",
    "audit:portal-external": "node ./scripts/audit-web-artifact.mjs --external-strict",
    "audit:player-artifact": "node ./scripts/audit-web-artifact.mjs --player --strict",
    "audit:player-portal": "node ./scripts/audit-web-artifact.mjs --player --strict --external-strict",
    "audit:admin-artifact": "node ./scripts/audit-web-artifact.mjs --admin --strict",
    "report:player-build": "node ./scripts/report-player-build.mjs",
    "verify:player:standalone": "pnpm build:standalone && pnpm report:player-build -- --expect=standalone && pnpm audit:player-portal",
    "verify:player:poki": "pnpm build:poki && pnpm report:player-build -- --expect=poki && pnpm audit:player-portal",
    "verify:player:crazygames": "pnpm build:crazygames && pnpm report:player-build -- --expect=crazygames && pnpm audit:player-portal",
    "check:deployment-contract": "node ./scripts/check-deployment-contract.mjs",
    "check:runtime-routes": "node ./scripts/check-runtime-routes.mjs",
    "audit:production:player": "node ./scripts/check-production-player.mjs",
    "audit:production:player:strict": "node ./scripts/check-production-player.mjs --strict",
    "check:player-boundaries": "node ./scripts/check-player-boundaries.mjs",
    "check:app-source-boundaries": "node ./scripts/check-app-source-boundaries.mjs",
    "release:check": "node ./scripts/release-check.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
